generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  free
  monthly
  semester
  annual
}

enum PaymentProvider {
  stripe
  paypal
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum AuthProvider {
  email
  google
}

enum SubscriptionCancelReason {
  too_expensive
  not_using_enough
  exam_finished_or_paused
  found_alternative
  technical_issues
  content_not_expected
  prefer_not_to_say
  other
}

enum StudyPlanStatus {
  pending
  in_progress
  completed
  skipped
}

enum StudyPlanTaskType {
  question_set
  flashcard_set
  mini_case
}

enum ExamFeedbackDifficulty {
  easy
  medium
  hard
}

enum CaseTextFormat {
  plain
  html
}

enum MentorshipStatus {
  pending
  accepted
  rejected
  scheduled
  completed
  cancelled
}

enum WellbeingMood {
  very_low
  low
  neutral
  good
  great
}

enum WellbeingInterventionKind {
  breathing
  pomodoro
  break_reset
  grounding
  stretch
}

enum PlatformSuggestionSource {
  modal
  mailbox
}

model Profile {
  id                    String            @id @default(uuid())
  email                 String            @unique
  password              String
  authProvider          AuthProvider      @default(email) @map("auth_provider")
  firstName             String            @map("first_name")
  lastName              String            @map("last_name")
  university            String?
  graduationYear        Int?              @map("graduation_year")
  examDate              DateTime?         @map("exam_date")
  avatarUrl             String?           @map("avatar_url")
  onboardingDone        Boolean           @default(false) @map("onboarding_done")
  /** Si existe, ya se generó el examen de bienvenida post-onboarding (idempotencia). */
  onboardingWelcomeExamCreatedAt DateTime? @map("onboarding_welcome_exam_created_at")
  subscriptionTier               SubscriptionTier  @default(free) @map("subscription_tier")
  subscriptionExpiresAt          DateTime?         @map("subscription_expires_at")
  stripeCustomerId               String?           @map("stripe_customer_id")
  stripeSubscriptionId           String?           @unique @map("stripe_subscription_id")
  paypalSubscriptionId           String?           @unique @map("paypal_subscription_id")
  subscriptionCancelAtPeriodEnd  Boolean           @default(false) @map("subscription_cancel_at_period_end")
  freeTrialExamsUsed             Int               @default(0) @map("free_trial_exams_used")
  adminPushNotifyNewUser         Boolean           @default(true) @map("admin_push_notify_new_user")
  adminPushNotifyNewSubscription Boolean           @default(true) @map("admin_push_notify_new_subscription")
  adminEmailNotifyNewUser         Boolean           @default(false) @map("admin_email_notify_new_user")
  adminEmailNotifyNewSubscription Boolean           @default(false) @map("admin_email_notify_new_subscription")
  wellbeingPushEnabled            Boolean           @default(false) @map("wellbeing_push_enabled")
  wellbeingReminderTime           String?           @map("wellbeing_reminder_time") @db.VarChar(5)
  wellbeingReminderDays           String?           @map("wellbeing_reminder_days") @db.VarChar(32)
  /** Si existe, ya no se muestra el modal ocasional de sugerencias en el Dashboard. */
  platformSuggestionPromptHandledAt DateTime?       @map("platform_suggestion_prompt_handled_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  roles    UserRole[]
  adminWebPushSubscriptions AdminWebPushSubscription[]
  exams    Exam[]
  answers  UserAnswer[]
  studyPlans StudyPlan[]
  studyPlanExecutions StudyPlanExecution[]
  payments                           Payment[]
  subscriptionCancellationFeedbacks SubscriptionCancellationFeedback[]
  createdClinicalCases              ClinicalCase[] @relation("ClinicalCaseCreatedBy")
  updatedClinicalCases              ClinicalCase[] @relation("ClinicalCaseUpdatedBy")
  mentorExamReviews                 Exam[]         @relation("MentorExamReviews")
  examFeedbacks                    ExamStudentFeedback[]
  collaboratorCodeId                String?        @map("collaborator_code_id")
  collaboratorCode                  CollaboratorCode? @relation(fields: [collaboratorCodeId], references: [id], onDelete: SetNull)
  communityThreads                 CommunityThread[]
  communityPosts                   CommunityPost[]
  mentorshipRequestsAsStudent      MentorshipRequest[] @relation("MentorshipStudent")
  mentorshipRequestsAsMentor       MentorshipRequest[] @relation("MentorshipMentor")
  wellbeingLogs                    DailyWellbeingLog[]
  wellbeingInterventions           WellbeingInterventionEvent[]
  userWebPushSubscriptions         UserWebPushSubscription[]
  platformSuggestions              PlatformSuggestion[]

  @@index([collaboratorCodeId])
  @@map("profiles")
}

model PlatformSuggestion {
  id        String                   @id @default(uuid())
  userId    String                   @map("user_id")
  message   String                   @db.Text
  source    PlatformSuggestionSource @default(mailbox)
  createdAt DateTime                 @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("platform_suggestions")
}

model SubscriptionCancellationFeedback {
  id        String                   @id @default(uuid())
  userId    String                   @map("user_id")
  provider  PaymentProvider
  reason    SubscriptionCancelReason
  details   String?                  @db.Text
  createdAt DateTime                 @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("subscription_cancellation_feedback")
}

model Payment {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  provider   PaymentProvider
  externalId String           @map("external_id")
  amount     Int
  currency   String           @default("mxn")
  status     PaymentStatus
  tier       SubscriptionTier
  metadata   Json?
  createdAt  DateTime         @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@map("payments")
}

enum AppRole {
  admin
  editor
  user
}

model UserRole {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  role   AppRole

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model AdminWebPushSubscription {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  endpoint     String   @db.Text
  endpointHash String   @unique @map("endpoint_hash") @db.VarChar(64)
  p256dh       String   @map("p256dh") @db.VarChar(512)
  auth         String   @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_web_push_subscriptions")
}

model Specialty {
  id   String @id @default(uuid())
  name String @unique

  areas           Area[]
  cases           ClinicalCase[]
  examSpecialties ExamSpecialty[]
  predictionCalibrations PredictionCalibration[]
  flashcardLinks FlashcardSpecialty[]
  communityThreads CommunityThread[]
  mentorshipRequests MentorshipRequest[]

  @@map("specialties")
}

model Area {
  id          String @id @default(uuid())
  name        String
  specialtyId String @map("specialty_id")

  specialty Specialty   @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  cases     ClinicalCase[]
  examAreas ExamArea[]
  flashcardLinks FlashcardArea[]

  @@unique([specialtyId, name])
  @@map("areas")
}

model ClinicalCase {
  id          String   @id @default(uuid())
  specialtyId String   @map("specialty_id")
  areaId      String   @map("area_id")
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  topic       String
  language    String   @default("es")
  text        String   @db.Text
  textFormat  CaseTextFormat @default(plain) @map("text_format")
  imageUrl    String?  @map("image_url")
  generatedByIa Boolean @default(false) @map("generated_by_ia")
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  specialty  Specialty    @relation(fields: [specialtyId], references: [id])
  area       Area         @relation(fields: [areaId], references: [id])
  createdBy  Profile?     @relation("ClinicalCaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  Profile?     @relation("ClinicalCaseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  questions  Question[]
  labResults LabResult[]
  examCases  ExamCase[]

  @@index([createdById])
  @@index([updatedById])
  @@map("clinical_cases")
}

model LabResult {
  id          String @id @default(uuid())
  caseId      String @map("case_id")
  name        String
  value       String
  unit        String
  normalRange String @map("normal_range")

  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("lab_results")
}

model Question {
  id                    String   @id @default(uuid())
  caseId                String   @map("case_id")
  text                  String   @db.Text
  imageUrl              String?  @map("image_url")
  feedbackImageUrl      String?  @map("feedback_image_url")
  summary               String   @db.Text
  bibliography          String   @db.Text
  difficultyLevel       Int      @default(2) @map("difficulty_level")
  cognitiveCompetence   Boolean  @default(false) @map("cognitive_competence")
  previousEnarmPresence Boolean  @default(false) @map("previous_enarm_presence")
  hint                  String   @db.Text
  orderIndex            Int      @default(0) @map("order_index")
  deletedAt             DateTime? @map("deleted_at")

  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  options       AnswerOption[]
  userAnswers   UserAnswer[]
  examQuestions ExamQuestion[]

  @@index([caseId, deletedAt])
  @@map("questions")
}

model AnswerOption {
  id                 String  @id @default(uuid())
  questionId         String  @map("question_id")
  label              String
  text               String  @db.Text
  imageUrl           String? @map("image_url")
  feedbackImageUrl   String? @map("feedback_image_url")
  isCorrect          Boolean @default(false) @map("is_correct")
  explanation        String  @db.Text

  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userAnswers UserAnswer[]

  @@map("answer_options")
}

model Exam {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  mode             String
  adaptiveMode     Boolean   @default(false) @map("adaptive_mode")
  language         String    @default("es")
  questionCount    Int       @map("question_count")
  questionFilter   String    @default("all") @map("question_filter")
  status           String    @default("not_started")
  currentIndex     Int       @default(0) @map("current_question_index")
  score            Float?
  predictionSpecialty          String?  @map("prediction_specialty")
  predictionVersion            String?  @map("prediction_version")
  predictedPercentile          Float?   @map("predicted_percentile")
  predictedPlacementProbability Float?  @map("predicted_placement_probability")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  timeSpentSeconds Int       @default(0) @map("time_spent_seconds")
  createdAt        DateTime  @default(now()) @map("created_at")
  isOnboardingWelcome     Boolean  @default(false) @map("is_onboarding_welcome")
  welcomeLeadInFirstName  String?  @map("welcome_lead_in_first_name") @db.VarChar(255)
  welcomeLeadInUniversity String?  @map("welcome_lead_in_university") @db.VarChar(512)

  mentorReviewEligible   Boolean   @default(false) @map("mentor_review_eligible")
  studentFeedbackEligible Boolean  @default(false) @map("student_feedback_eligible")
  mentorReviewRating     Int?      @map("mentor_review_rating")
  mentorReviewComment    String?   @db.Text @map("mentor_review_comment")
  mentorReviewedAt       DateTime? @map("mentor_reviewed_at")
  mentorReviewedById     String?   @map("mentor_reviewed_by_id")

  user      Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorReviewedBy Profile? @relation("MentorExamReviews", fields: [mentorReviewedById], references: [id], onDelete: SetNull)
  examCases    ExamCase[]
  examQuestions ExamQuestion[]
  answers      UserAnswer[]
  studentFeedback ExamStudentFeedback?

  selectedSpecialties ExamSpecialty[]
  selectedAreas       ExamArea[]

  @@map("exams")
}

model ExamStudentFeedback {
  id         String                 @id @default(uuid())
  userId     String                 @map("user_id")
  examId     String                 @unique @map("exam_id")
  difficulty ExamFeedbackDifficulty
  rating     Int
  comment    String?                @db.Text
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("exam_student_feedback")
}

model ExamSpecialty {
  examId      String @map("exam_id")
  specialtyId String @map("specialty_id")

  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([examId, specialtyId])
  @@map("exam_specialties")
}

model ExamArea {
  examId String @map("exam_id")
  areaId String @map("area_id")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  area Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([examId, areaId])
  @@map("exam_areas")
}

model ExamCase {
  examId     String @map("exam_id")
  caseId     String @map("case_id")
  orderIndex Int    @default(0) @map("order_index")

  exam         Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id])

  @@id([examId, caseId])
  @@map("exam_cases")
}

model ExamQuestion {
  examId     String @map("exam_id")
  questionId String @map("question_id")
  orderIndex Int    @default(0) @map("order_index")

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@map("exam_questions")
}

model UserAnswer {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  examId           String   @map("exam_id")
  questionId       String   @map("question_id")
  selectedOptionId String?  @map("selected_option_id")
  isCorrect        Boolean? @map("is_correct")
  answeredAt       DateTime @default(now()) @map("answered_at")
  responseTimeSeconds Int?  @map("response_time_seconds")
  questionDifficulty  Int?  @map("question_difficulty")

  user     Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam     Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id])
  option   AnswerOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([examId, questionId])
  @@map("user_answers")
}

model PredictionCalibration {
  id                 String   @id @default(uuid())
  specialtyId        String   @map("specialty_id")
  version            String   @default("v1")
  minScore           Float    @map("min_score")
  maxScore           Float    @map("max_score")
  percentileEstimate Float    @map("percentile_estimate")
  probabilityEstimate Float   @map("probability_estimate")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@index([specialtyId, version])
  @@index([specialtyId, minScore, maxScore])
  @@map("prediction_calibrations")
}

model Flashcard {
  id        String   @id @default(uuid())
  question  String   @db.Text
  answer    String   @db.Text
  hint      String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  specialties FlashcardSpecialty[]
  areas       FlashcardArea[]

  @@map("flashcards")
}

model FlashcardSpecialty {
  flashcardId String @map("flashcard_id")
  specialtyId String @map("specialty_id")

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([flashcardId, specialtyId])
  @@map("flashcard_specialties")
}

model FlashcardArea {
  flashcardId String @map("flashcard_id")
  areaId      String @map("area_id")

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  area      Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([flashcardId, areaId])
  @@map("flashcard_areas")
}

model StudyPlan {
  id                        String         @id @default(uuid())
  userId                    String         @map("user_id")
  date                      DateTime
  status                    StudyPlanStatus @default(pending)
  isFreeLimited             Boolean        @default(false) @map("is_free_limited")
  targetMinutes             Int            @default(30) @map("target_minutes")
  estimatedScoreDelta       Float          @default(0) @map("estimated_score_delta")
  estimatedPercentileDelta  Float          @default(0) @map("estimated_percentile_delta")
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")

  user       Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      StudyPlanTask[]
  executions StudyPlanExecution[]

  @@unique([userId, date])
  @@index([userId, status])
  @@map("study_plans")
}

model StudyPlanTask {
  id             String           @id @default(uuid())
  studyPlanId    String           @map("study_plan_id")
  taskType       StudyPlanTaskType @map("task_type")
  title          String
  description    String?          @db.Text
  targetCount    Int              @default(0) @map("target_count")
  completedCount Int              @default(0) @map("completed_count")
  payload        Json?
  sortOrder      Int              @default(0) @map("sort_order")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  studyPlan  StudyPlan             @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  executions StudyPlanExecution[]

  @@index([studyPlanId, taskType])
  @@map("study_plan_tasks")
}

model StudyPlanExecution {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  studyPlanId      String   @map("study_plan_id")
  studyPlanTaskId  String   @map("study_plan_task_id")
  completed        Boolean  @default(false)
  score            Float?
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlan StudyPlan    @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  task      StudyPlanTask @relation(fields: [studyPlanTaskId], references: [id], onDelete: Cascade)

  @@unique([userId, studyPlanId, studyPlanTaskId])
  @@index([userId, completedAt])
  @@map("study_plan_executions")
}

model DailyWellbeingLog {
  id                   String       @id @default(uuid())
  userId               String       @map("user_id")
  date                 DateTime
  mood                 WellbeingMood
  anxietyLevel         Int          @map("anxiety_level")
  focusLevel           Int          @map("focus_level")
  sleepHours           Float?       @map("sleep_hours")
  plannedStudyMinutes  Int          @default(0) @map("planned_study_minutes")
  completedStudyMinutes Int         @default(0) @map("completed_study_minutes")
  notes                String?      @db.Text
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, createdAt])
  @@map("daily_wellbeing_logs")
}

model WellbeingInterventionEvent {
  id              String                    @id @default(uuid())
  userId          String                    @map("user_id")
  date            DateTime
  kind            WellbeingInterventionKind
  durationMinutes Int                       @default(5) @map("duration_minutes")
  completed       Boolean                   @default(true)
  createdAt       DateTime                  @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, kind, createdAt])
  @@map("wellbeing_intervention_events")
}

model UserWebPushSubscription {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  endpoint     String   @db.Text
  endpointHash String   @unique @map("endpoint_hash") @db.VarChar(64)
  p256dh       String   @map("p256dh") @db.VarChar(512)
  auth         String   @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_web_push_subscriptions")
}

model CommunityThread {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  specialtyId String?  @map("specialty_id")
  title       String
  body        String   @db.Text
  isLocked    Boolean  @default(false) @map("is_locked")
  isPinned    Boolean  @default(false) @map("is_pinned")
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author    Profile    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  specialty Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  posts     CommunityPost[]

  @@index([authorId, createdAt])
  @@index([specialtyId, createdAt])
  @@index([isPinned, createdAt])
  @@index([isHidden, createdAt])
  @@map("community_threads")
}

model CommunityPost {
  id           String   @id @default(uuid())
  threadId     String   @map("thread_id")
  authorId     String   @map("author_id")
  parentPostId String?  @map("parent_post_id")
  body         String   @db.Text
  isHidden     Boolean  @default(false) @map("is_hidden")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  thread     CommunityThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     Profile         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentPost CommunityPost?  @relation("CommunityPostReplies", fields: [parentPostId], references: [id], onDelete: SetNull)
  replies    CommunityPost[] @relation("CommunityPostReplies")

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentPostId])
  @@index([isHidden, createdAt])
  @@map("community_posts")
}

model MentorshipRequest {
  id                 String           @id @default(uuid())
  studentId          String           @map("student_id")
  mentorId           String?          @map("mentor_id")
  specialtyId        String?          @map("specialty_id")
  topic              String
  context            String?          @db.Text
  availability       String?          @db.Text
  status             MentorshipStatus @default(pending)
  statusNote         String?          @map("status_note") @db.Text
  externalMeetingUrl String?          @map("external_meeting_url")
  scheduledAt        DateTime?        @map("scheduled_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  student   Profile    @relation("MentorshipStudent", fields: [studentId], references: [id], onDelete: Cascade)
  mentor    Profile?   @relation("MentorshipMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  specialty Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([mentorId, createdAt])
  @@index([specialtyId, createdAt])
  @@index([status, createdAt])
  @@map("mentorship_requests")
}

model MotivationalPhrase {
  id        String   @id @default(uuid())
  text      String   @db.Text
  author    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("motivational_phrases")
}

model ExamDate {
  id       String   @id @default(uuid())
  name     String
  date     DateTime
  isActive Boolean  @default(true) @map("is_active")

  @@map("exam_dates")
}

model SubscriptionPlan {
  id          String            @id @default(uuid())
  name        String
  price       Float
  duration    Int
  features    String            @db.Text
  isActive    Boolean           @default(true) @map("is_active")
  highlighted Boolean           @default(false)
  /** Opcional: monthly | semester | annual para enlazar con el checkout sin depender solo de `duration`. */
  tier         SubscriptionTier?
  /** ID de plan de facturación PayPal (P-...); se rellena al crear el plan por API o manualmente en backoffice. */
  paypalPlanId String?           @map("paypal_plan_id")

  @@index([tier])
  @@map("subscription_plans")
}

/** Código promocional Stripe (primer periodo): cupón `once` + promotion code en Stripe. */
model PromotionCode {
  id                    String    @id @default(uuid())
  /** Código en mayúsculas para búsqueda estable. */
  code                  String    @unique
  percentOff            Int       @map("percent_off")
  maxRedemptions        Int?      @map("max_redemptions")
  validFrom             DateTime? @map("valid_from")
  validUntil            DateTime? @map("valid_until")
  isActive              Boolean   @default(true) @map("is_active")
  stripeCouponId        String    @map("stripe_coupon_id")
  stripePromotionCodeId String    @unique @map("stripe_promotion_code_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  collaboratorCode CollaboratorCode?

  @@map("promotion_codes")
}

/** Código de colaborador: solo atribución o atribución + descuento (vía PromotionCode). */
model CollaboratorCode {
  id               String    @id @default(uuid())
  /** Mismo formato que PromotionCode: mayúsculas para búsqueda estable. */
  code             String    @unique
  displayName      String    @map("display_name")
  /** Si existe, el checkout aplica el descuento Stripe de este código promocional. */
  promotionCodeId  String?   @unique @map("promotion_code_id")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  promotionCode PromotionCode? @relation(fields: [promotionCodeId], references: [id], onDelete: SetNull)
  profiles      Profile[]

  @@map("collaborator_codes")
}
