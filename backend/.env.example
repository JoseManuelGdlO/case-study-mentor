DATABASE_URL=mysql://user:pass@localhost:3306/enarm_db
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-to-at-least-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars-minimum
# Mismo ID que VITE_GOOGLE_CLIENT_ID en frontend/.env (verificación del id_token en el servidor)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
PORT=3001
CORS_ORIGIN=http://localhost:8080
NODE_ENV=development
UPLOAD_DIR=uploads
