DATABASE_URL=mysql://user:pass@localhost:3306/enarm_db
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-to-at-least-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars-minimum
# Mismo ID que VITE_GOOGLE_CLIENT_ID en frontend/.env (verificación del id_token en el servidor)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
PORT=3001
# Un origen o varios separados por coma (sin espacios obligatorios; se recortan)
CORS_ORIGIN=http://localhost:8080
# Ejemplo producción: CORS_ORIGIN=https://app.ejemplo.com,https://www.ejemplo.com
NODE_ENV=development
# Directorio relativo al cwd del proceso (en Docker: /app/uploads). Las URLs públicas son /uploads/...
# Persistencia: en docker-compose.yml se monta el host en /app/uploads (HOST_UPLOADS_BIND, p. ej. /images en VPS).
UPLOAD_DIR=uploads

# Pagos (opcionales; sin ellos los endpoints de checkout responden 503)
# Obligatorio en producción para Stripe/PayPal: URL pública del sitio (success/cancel del checkout).
# FRONTEND_URL=https://enarm.com.mx
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Los precios de planes salen de la tabla subscription_plans (backoffice), no de variables de entorno.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Correo (recuperar contraseña). En producción son obligatorios para /api/auth/forgot-password.
# SMTP_SECURE=true suele usarse con puerto 465.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_SECURE=
